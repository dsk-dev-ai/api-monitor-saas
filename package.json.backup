{
  "name": "api-monitor-saas",
  "version": "1.0.0",
  "description": "API Monitor SaaS - v1 MVP",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "worker"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:worker\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:worker": "cd worker && npm run dev",
    "build": "node scripts/validate-env.js && npm run build:backend && npm run build:frontend && npm run build:worker",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:worker": "cd worker && npm run build",
    "start": "node scripts/validate-env.js && cd backend && npm start",
    "db:push": "cd backend && npx prisma db push",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:studio": "cd backend && npx prisma studio",
    "db:generate": "cd backend && npx prisma generate",
    "test": "cd backend && npm test",
    "lint": "cd frontend && npm run lint && cd ../backend && npm run lint",
    "validate:env": "node scripts/validate-env.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
