generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  avatar       String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  alerts       Alert[]
  monitors     Monitor[]
  statusPages  StatusPage[]
  subscription Subscription?

  @@map("users")
}

model Monitor {
  id              String           @id @default(cuid())
  name            String
  url             String
  method          String           @default("GET")
  headers         Json?            @default("{}")
  body            String?
  interval        Int              @default(300)
  timeout         Int              @default(30)
  expectedStatus  Int?             @default(200) @map("expected_status")
  expectedKeyword String?          @map("expected_keyword")
  isActive        Boolean          @default(true) @map("is_active")
  isPaused        Boolean          @default(false) @map("is_paused")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userId          String           @map("user_id")
  region          String           @default("global")
  alerts          Alert[]
  checks          Check[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  statusPageItems StatusPageItem[]

  @@index([userId])
  @@index([isActive])
  @@index([isPaused])
  @@map("monitors")
}

model Check {
  id           String   @id @default(cuid())
  monitorId    String   @map("monitor_id")
  status       String
  statusCode   Int?     @map("status_code")
  responseTime Int      @map("response_time")
  error        String?
  checkedAt    DateTime @default(now()) @map("checked_at")
  region       String   @default("global")
  monitor      Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([checkedAt])
  @@index([status])
  @@map("checks")
}

model Alert {
  id         String    @id @default(cuid())
  monitorId  String    @map("monitor_id")
  userId     String    @map("user_id")
  type       String
  status     String    @default("triggered")
  message    String
  details    Json?
  sentAt     DateTime  @default(now()) @map("sent_at")
  resolvedAt DateTime? @map("resolved_at")
  monitor    Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([monitorId])
  @@index([userId])
  @@index([status])
  @@index([sentAt])
  @@map("alerts")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  stripeCustomerId     String    @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  status               String    @default("free")
  plan                 String    @default("free")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model StatusPage {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  isPublic    Boolean          @default(true) @map("is_public")
  logo        String?
  brandColor  String           @default("#3b82f6") @map("brand_color")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  userId      String           @map("user_id")
  items       StatusPageItem[]
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("status_pages")
}

model StatusPageItem {
  id           String     @id @default(cuid())
  statusPageId String     @map("status_page_id")
  monitorId    String     @map("monitor_id")
  displayName  String?    @map("display_name")
  order        Int        @default(0)
  monitor      Monitor    @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  statusPage   StatusPage @relation(fields: [statusPageId], references: [id], onDelete: Cascade)

  @@unique([statusPageId, monitorId])
  @@map("status_page_items")
}
